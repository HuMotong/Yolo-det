{
  "version": "0.2.0",
  "configurations": [
    {
      // Debug current file
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      // Debug current file with subprocesses (multiprocessing)
      "name": "Python: Current File (subprocess)",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "subProcess": true
    }
  ]
}
